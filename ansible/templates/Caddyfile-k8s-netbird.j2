# Caddyfile - Kubernetes Migration via NetBird
# Managed by Ansible - ansible/playbooks/configure-vps-k8s-routes.yml

# Global options
{
    # Email for Let's Encrypt notifications
    email {{ caddy_email | default('bearflinn@gmail.com') }}

    # Automatic HTTPS

    # Admin endpoint (local only)
    admin localhost:2019

    # Log settings
    log {
        output file /var/log/caddy/caddy.log
        format json
        level INFO
    }
}

# =============================================================================
# EXISTING SERVICES - PRESERVED
# =============================================================================

{% for service in existing_services %}
{% if service.type | default('proxy') == 'static' %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    root * {{ service.root }}
    file_server
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

{% else %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    reverse_proxy {{ service.backend }}

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/access.log
        format json
    }
}

{% endif %}
{% endfor %}

# =============================================================================
# KUBERNETES SERVICES - Routed via NetBird to K8s Ingress
# Endpoint: {{ k8s_ingress_endpoint }}
# =============================================================================

{% for service in k8s_services %}
{% if service.enabled | default(true) %}
# {{ service.domain }} - K8s service
{{ service.domain }} {
    reverse_proxy http://{{ k8s_ingress_endpoint }} {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file /var/log/caddy/k8s-access.log
        format json
    }
}

{% endif %}
{% endfor %}
