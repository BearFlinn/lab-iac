# Managed by Ansible — r730xd-minio-bulk role
# MinIO Bulk: container registry and build artifacts on MergerFS
# Data: {{ minio_bulk_data_dir }}

services:
  minio:
    image: {{ minio_bulk_image }}
    container_name: minio-bulk
    restart: unless-stopped
    ports:
      - "{{ minio_bulk_api_port }}:9000"
      - "{{ minio_bulk_console_port }}:9001"
    environment:
      MINIO_ROOT_USER: "{{ minio_bulk_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_bulk_root_password }}"
      MINIO_PROMETHEUS_AUTH_TYPE: "public"
    volumes:
      - {{ minio_bulk_data_dir }}:/data
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
