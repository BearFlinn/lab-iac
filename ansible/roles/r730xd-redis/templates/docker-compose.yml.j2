# Managed by Ansible — r730xd-redis role
# Foundation Redis for grizzly-platform services
# Data: {{ redis_data_dir }}

services:
  redis:
    image: {{ redis_image }}
    container_name: foundation-redis
    restart: unless-stopped
    network_mode: host
    volumes:
      - {{ redis_data_dir }}:/data
      - {{ redis_compose_dir }}/redis.conf:/usr/local/etc/redis/redis.conf:ro
    command: ["redis-server", "/usr/local/etc/redis/redis.conf"]
    healthcheck:
      test: ["CMD", "redis-cli", "-p", "{{ redis_port }}", "-a", "{{ redis_password }}", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
