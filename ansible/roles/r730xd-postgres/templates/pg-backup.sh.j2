#!/usr/bin/env bash
# Managed by Ansible — r730xd-postgres role
# Daily pg_dumpall backup with rotation
set -euo pipefail

BACKUP_DIR="{{ postgres_backup_dir }}"
RETENTION_DAYS="{{ postgres_backup_retention_days }}"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
BACKUP_FILE="${BACKUP_DIR}/pg_dumpall-${TIMESTAMP}.sql.gz"

# Dump all databases
docker exec foundation-postgres pg_dumpall -U postgres | gzip > "${BACKUP_FILE}"

# Verify the dump is non-empty
if [ ! -s "${BACKUP_FILE}" ]; then
    echo "ERROR: Backup file is empty: ${BACKUP_FILE}" >&2
    rm -f "${BACKUP_FILE}"
    exit 1
fi

# Rotate old backups
find "${BACKUP_DIR}" -name "pg_dumpall-*.sql.gz" -mtime "+${RETENTION_DAYS}" -delete

echo "Backup complete: ${BACKUP_FILE} ($(du -h "${BACKUP_FILE}" | cut -f1))"
