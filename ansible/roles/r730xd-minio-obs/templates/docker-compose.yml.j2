# Managed by Ansible — r730xd-minio-obs role
# MinIO Obs: observability S3 backend (Loki, Tempo) on ZFS
# Data: {{ minio_obs_data_dir }}

services:
  minio:
    image: {{ minio_obs_image }}
    container_name: minio-obs
    restart: unless-stopped
    ports:
      - "{{ minio_obs_api_port }}:9000"
      - "{{ minio_obs_console_port }}:9001"
    environment:
      MINIO_ROOT_USER: "{{ minio_obs_root_user }}"
      MINIO_ROOT_PASSWORD: "{{ minio_obs_root_password }}"
      MINIO_PROMETHEUS_AUTH_TYPE: "public"
    volumes:
      - {{ minio_obs_data_dir }}:/data
    command: server /data --console-address ":9001"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:9000/minio/health/live"]
      interval: 10s
      timeout: 5s
      retries: 5
