# Caddyfile - K8s Proxy Configuration
# Managed by Ansible - DO NOT EDIT MANUALLY
# This template includes reverse proxy rules for Kubernetes cluster services
#
# TEMPLATE SELECTION GUIDE:
# -------------------------
# Use this template (Caddyfile-k8s.j2) for:
#   - Proxying traffic to a Kubernetes cluster via NetBird VPN
#   - proxy-vps deployments routing to home cluster
#   - Requires k8s_proxy_routes variable to define backend routes
#
# Use Caddyfile.j2 instead when:
#   - Simple static file serving without Kubernetes
#   - No reverse proxy requirements
#   - Standalone web hosting (e.g., deb-web server)
#
# Required variables for k8s_proxy_routes entries:
#   - domain: Hostname to match (e.g., app.example.com)
#   - type: 'k8s_api' or 'k8s_ingress'
#   - backend: For k8s_api type, the API server URL
#   - backend_service, backend_namespace, backend_port: For k8s_ingress type

# Global options
{
    # Email for Let's Encrypt notifications
{% if caddy_email %}
    email {{ caddy_email }}
{% endif %}

    # Automatic HTTPS
{% if not caddy_auto_https %}
    auto_https off
{% endif %}

    # Admin endpoint (local only)
    admin localhost:2019

    # Log settings
    log {
        output file {{ caddy_log_dir }}/caddy.log
        format json
        level INFO
    }
}

# Wildcard certificate configuration with DNS-01 challenge
{% if caddy_use_wildcard and caddy_wildcard_domain %}
{{ caddy_domain }}{% if caddy_wildcard_domain %}, {{ caddy_wildcard_domain }}{% endif %} {
    # TLS configuration for DNS-01 challenge
    tls {
{% if caddy_dns_provider %}
        dns {{ caddy_dns_provider }} {env.{% if caddy_dns_provider == 'cloudflare' %}CLOUDFLARE_API_TOKEN{% elif caddy_dns_provider == 'route53' %}AWS_ACCESS_KEY_ID{% elif caddy_dns_provider == 'digitalocean' %}DO_AUTH_TOKEN{% endif %}}
{% endif %}
    }

    # Security headers (applied to all routes)
    header {
        # Enable HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server header
        -Server
    }

    # Kubernetes cluster proxy routes
{% if k8s_proxy_routes is defined and k8s_proxy_routes | length > 0 %}
{% for route in k8s_proxy_routes %}
    # Route: {{ route.domain }}{% if route.type == 'k8s_api' %} (K8s API Server){% elif route.type == 'k8s_ingress' %} (K8s Ingress: {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local){% endif %}
    @route_{{ loop.index0 }} host {{ route.domain }}
    handle @route_{{ loop.index0 }} {
{% if route.type == 'k8s_api' %}
        # Proxy to Kubernetes API Server
        reverse_proxy {{ route.backend }} {
            # For self-signed certificates on k8s API server
{% if route.skip_verify | default(false) %}
            transport http {
                tls_insecure_skip_verify
            }
{% endif %}
            # Preserve original headers
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up Authorization "{http.request.header.Authorization}"

            # Websocket support
            websocket
        }
{% elif route.type == 'k8s_ingress' %}
        # Proxy to Kubernetes Ingress Service
        # Backend: {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local:{{ route.backend_port }}
        reverse_proxy {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local:{{ route.backend_port }} {
            # Preserve original headers for proper ingress routing
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Uri {http.request.uri}

            # Websocket support for real-time applications
            websocket

            # Health check for backend availability
            health_uri /healthz
            health_status 200
        }
{% endif %}

        # Access logging for this route
        log {
            output file {{ caddy_log_dir }}/access.log
            format json
        }
    }
{% endfor %}

{% endif %}
    # Root domain handler (static content)
    @root host {{ caddy_domain }}
    handle @root {
        root * /var/www/html
        file_server
        encode gzip

        log {
            output file {{ caddy_log_dir }}/access.log
            format json
        }
    }

    # Catch-all for subdomains not matched by k8s routes (serves static content or error page)
    handle {
        root * /var/www/html
        file_server
        encode gzip

        log {
            output file {{ caddy_log_dir }}/access.log
            format json
        }
    }

{{ caddy_additional_config | indent(4, first=True) }}
}

{% elif caddy_domain and caddy_domain != 'localhost' %}
# Standard configuration with HTTP-01 challenge and K8s proxy
{{ caddy_domain }} {
    # Security headers (applied to all routes)
    header {
        # Enable HSTS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME sniffing
        X-Content-Type-Options "nosniff"
        # XSS protection
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Remove server header
        -Server
    }

    # Kubernetes cluster proxy routes
{% if k8s_proxy_routes is defined and k8s_proxy_routes | length > 0 %}
{% for route in k8s_proxy_routes %}
    # Route: {{ route.domain }}{% if route.type == 'k8s_api' %} (K8s API Server){% elif route.type == 'k8s_ingress' %} (K8s Ingress: {{ route.backend_service }}.{{ route.backend_namespace }}){% endif %}
    @route_{{ loop.index0 }} host {{ route.domain }}
    handle @route_{{ loop.index0 }} {
{% if route.type == 'k8s_api' %}
        # Proxy to Kubernetes API Server
        reverse_proxy {{ route.backend }} {
            # For self-signed certificates on k8s API server
{% if route.skip_verify | default(false) %}
            transport http {
                tls_insecure_skip_verify
            }
{% endif %}
            # Preserve original headers
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up Authorization "{http.request.header.Authorization}"

            # Websocket support
            websocket
        }
{% elif route.type == 'k8s_ingress' %}
        # Proxy to Kubernetes Ingress Service
        # Backend: {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local:{{ route.backend_port }}
        reverse_proxy {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local:{{ route.backend_port }} {
            # Preserve original headers for proper ingress routing
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            header_up X-Forwarded-Uri {http.request.uri}

            # Websocket support for real-time applications
            websocket

            # Health check for backend availability
            health_uri /healthz
            health_status 200
        }
{% endif %}

        # Access logging for this route
        log {
            output file {{ caddy_log_dir }}/access.log
            format json
        }
    }
{% endfor %}

{% endif %}
    # Root domain handler (static content)
    root * /var/www/html
    file_server
    encode gzip

    # Access logging
    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }

{{ caddy_additional_config | indent(4, first=True) }}
}

{% else %}
# Development configuration - HTTP only with K8s proxy
:80 {
    # Kubernetes cluster proxy routes (if defined)
{% if k8s_proxy_routes is defined and k8s_proxy_routes | length > 0 %}
{% for route in k8s_proxy_routes %}
    @route_{{ loop.index0 }} host {{ route.domain }}
    handle @route_{{ loop.index0 }} {
{% if route.type == 'k8s_api' %}
        # Proxy to Kubernetes API Server
        reverse_proxy {{ route.backend }} {
            websocket
        }
{% elif route.type == 'k8s_ingress' %}
        # Proxy to Kubernetes Ingress Service
        reverse_proxy {{ route.backend_service }}.{{ route.backend_namespace }}.svc.cluster.local:{{ route.backend_port }} {
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
            websocket
        }
{% endif %}

        log {
            output file {{ caddy_log_dir }}/access.log
            format json
        }
    }
{% endfor %}

{% endif %}
    # Default handler (static content)
    root * /var/www/html
    file_server
    encode gzip

    # Access logging
    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }

{{ caddy_additional_config | indent(4, first=True) }}
}
{% endif %}
