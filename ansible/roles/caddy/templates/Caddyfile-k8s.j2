# Caddyfile - Kubernetes Reverse Proxy Configuration
# Managed by Ansible - ansible/roles/caddy

# Global options
{
    # Email for Let's Encrypt notifications
    email {{ caddy_email }}

{% if caddy_dns_provider | default('') == 'cloudflare' %}
    # DNS-01 ACME challenge via Cloudflare
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
{% endif %}

    # Admin endpoint (local only)
    admin localhost:2019

    # Log settings
    log {
        output file {{ caddy_log_dir }}/caddy.log
        format json
        level INFO
    }
}

# =============================================================================
# STATIC/PROXY SERVICES
# =============================================================================

{% for service in caddy_services | default([]) %}
{% if service.type | default('proxy') == 'static' %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    root * {{ service.root | default('/var/www/html') }}
    file_server
    encode gzip

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% else %}
# {{ service.comment | default(service.domain) }}
{{ service.domain }} {
    reverse_proxy {{ service.backend }}

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% endif %}
{% endfor %}
# =============================================================================
# KUBERNETES SERVICES - Routed via tunnel to K8s Ingress
# Endpoint: {{ k8s_ingress_endpoint }}
# =============================================================================

{% for service in k8s_services | default([]) %}
{% if service.enabled | default(true) %}
# {{ service.domain }} - K8s service
{{ service.domain }} {
    reverse_proxy http://{{ k8s_ingress_endpoint }} {
        header_up Host {host}
        header_up X-Real-IP {remote}
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "SAMEORIGIN"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/k8s-access.log
        format json
    }
}

{% endif %}
{% endfor %}
# =============================================================================
# ROOT DOMAIN REDIRECT
# =============================================================================

{% if caddy_root_domain is defined and caddy_root_redirect_target is defined %}
# Redirect root domain to {{ caddy_root_redirect_target }}
{{ caddy_root_domain }} {
    redir https://{{ caddy_root_redirect_target }}{uri} permanent

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}

{% endif %}
# =============================================================================
# WILDCARD CATCH-ALL - Returns 404 for unconfigured subdomains
# =============================================================================

{% if caddy_wildcard_catchall is defined %}
# Catch-all for unconfigured subdomains
{{ caddy_wildcard_catchall }} {
    respond "404 Not Found" 404

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        Content-Type "text/plain; charset=utf-8"
        -Server
    }

    log {
        output file {{ caddy_log_dir }}/access.log
        format json
    }
}
{% endif %}
