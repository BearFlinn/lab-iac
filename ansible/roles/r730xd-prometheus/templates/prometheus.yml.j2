# Managed by Ansible — r730xd-prometheus role
# Prometheus scrape configuration for homelab observability

global:
  scrape_interval: {{ prometheus_scrape_interval }}
  evaluation_interval: {{ prometheus_evaluation_interval }}

rule_files:
  - "rules/*.yml"

alerting:
  alertmanagers:
    - static_configs:
        - targets:
            - "localhost:{{ alertmanager_port }}"

scrape_configs:
  - job_name: "node"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/nodes.yml"
          - "/etc/prometheus/targets.d/node-*.yml"
        refresh_interval: 30s

  - job_name: "ipmi"
    scrape_interval: 30s
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/ipmi.yml"
          - "/etc/prometheus/targets.d/ipmi-*.yml"
        refresh_interval: 30s

{% for svc in prometheus_observability_targets %}
  - job_name: "{{ svc.job }}"
{% if svc.metrics_path is defined %}
    metrics_path: "{{ svc.metrics_path }}"
{% endif %}
    static_configs:
      - targets:
          - "{{ svc.target }}"
        labels:
          env: "homelab"

{% endfor %}
  - job_name: "etcd"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-etcd.yml"
        refresh_interval: 30s

{% if prometheus_k8s_apiserver_target is defined and prometheus_k8s_apiserver_target %}
  - job_name: "kube-apiserver"
    scheme: https
    tls_config:
      ca_file: /etc/prometheus/k8s-auth/ca.crt
      insecure_skip_verify: false
    authorization:
      credentials_file: /etc/prometheus/k8s-auth/token
    static_configs:
      - targets:
          - "{{ prometheus_k8s_apiserver_target }}"
        labels:
          env: "homelab"
          component: "kube-apiserver"
{% endif %}

  - job_name: "kubelet"
    scheme: https
    tls_config:
      ca_file: /etc/prometheus/k8s-auth/ca.crt
      # kubelet self-signed certs use hostnames, not IPs — skip server cert verification
      # Authentication is still enforced via bearer token + webhook authz
      insecure_skip_verify: true
    authorization:
      credentials_file: /etc/prometheus/k8s-auth/token
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-kubelet.yml"
        refresh_interval: 30s

  - job_name: "cilium-agent"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-cilium-agent.yml"
        refresh_interval: 30s

  - job_name: "cilium-operator"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-cilium-operator.yml"
        refresh_interval: 30s

  - job_name: "hubble"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-hubble.yml"
        refresh_interval: 30s

  - job_name: "kube-state-metrics"
    file_sd_configs:
      - files:
          - "/etc/prometheus/targets.d/k8s-kube-state-metrics.yml"
        refresh_interval: 30s

{% if prometheus_blackbox_targets is defined and prometheus_blackbox_targets | length > 0 %}
  - job_name: "blackbox"
    metrics_path: /probe
    params:
      module: [http_2xx]
    static_configs:
      - targets:
{% for target in prometheus_blackbox_targets %}
          - "{{ target }}"
{% endfor %}
    relabel_configs:
      - source_labels: [__address__]
        target_label: __param_target
      - source_labels: [__param_target]
        target_label: instance
      - target_label: __address__
        replacement: "{{ prometheus_blackbox_exporter }}"
{% endif %}
