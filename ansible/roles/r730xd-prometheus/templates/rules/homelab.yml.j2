# Managed by Ansible — r730xd-prometheus role
# Alert rules for homelab monitoring
# Source: docs/monitoring-integration.md

groups:
  - name: storage
    rules:
      - alert: DiskSpaceWarning
        expr: (1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100 > 85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Disk {{ '{{' }} $labels.mountpoint {{ '}}' }} is
            {{ '{{' }} $value | printf "%.0f" {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: DiskSpaceCritical
        expr: (1 - node_filesystem_avail_bytes / node_filesystem_size_bytes) * 100 > 95
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Disk {{ '{{' }} $labels.mountpoint {{ '}}' }} is
            {{ '{{' }} $value | printf "%.0f" {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: SmartUnhealthy
        expr: monitoring_smart_healthy == 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            SMART health check failed for {{ '{{' }} $labels.device {{ '}}' }}
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: DriveTemperatureHigh
        expr: monitoring_smart_temperature_celsius > 55
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            Drive {{ '{{' }} $labels.device {{ '}}' }} at
            {{ '{{' }} $value {{ '}}' }}°C
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ReallocatedSectors
        expr: monitoring_smart_reallocated_sectors > 5
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            {{ '{{' }} $value {{ '}}' }} reallocated sectors on
            {{ '{{' }} $labels.device {{ '}}' }}
            ({{ '{{' }} $labels.instance {{ '}}' }})

  - name: hardware
    rules:
      - alert: PSUFailure
        expr: monitoring_ipmi_psu_failed > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "Power supply failure detected on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: CPUTemperatureHigh
        expr: monitoring_ipmi_temperature_celsius > 85
        for: 5m
        labels:
          severity: critical
        annotations:
          summary: >-
            CPU at {{ '{{' }} $value {{ '}}' }}°C
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ECCMemoryErrors
        expr: monitoring_ipmi_memory_errors_sel > 0
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: "ECC memory errors detected on {{ '{{' }} $labels.instance {{ '}}' }}"

  - name: services
    rules:
      - alert: ServiceDown
        expr: monitoring_service_up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Service {{ '{{' }} $labels.service {{ '}}' }} is down
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: SystemdFailedUnits
        expr: monitoring_systemd_failed_units > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            {{ '{{' }} $value {{ '}}' }} failed systemd unit(s)
            on {{ '{{' }} $labels.instance {{ '}}' }}

  - name: nfs
    rules:
      - alert: NFSDown
        expr: monitoring_nfs_service_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "NFS server is down on {{ '{{' }} $labels.instance {{ '}}' }} — K8s PVCs affected"

      - alert: NFSRPCErrors
        expr: rate(node_nfsd_rpc_errors_total[5m]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            NFS RPC errors on {{ '{{' }} $labels.instance {{ '}}' }}
            ({{ '{{' }} $value | printf "%.2f" {{ '}}' }}/s)

  - name: snapraid
    rules:
      - alert: SnapRAIDErrors
        expr: monitoring_snapraid_errors > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: "SnapRAID sync errors on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: SnapRAIDScrubOverdue
        expr: monitoring_snapraid_last_scrub_days > 7
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            SnapRAID scrub is {{ '{{' }} $value {{ '}}' }} days overdue
            on {{ '{{' }} $labels.instance {{ '}}' }}

  - name: zfs
    rules:
      - alert: ZFSPoolDegraded
        expr: monitoring_zfs_pool_healthy == 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is unhealthy
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolCapacityWarning
        expr: monitoring_zfs_pool_capacity_percent > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is
            {{ '{{' }} $value {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolCapacityCritical
        expr: monitoring_zfs_pool_capacity_percent > 90
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} is
            {{ '{{' }} $value {{ '}}' }}% full
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSPoolErrors
        expr: monitoring_zfs_pool_errors > 0
        for: 0m
        labels:
          severity: critical
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} has
            {{ '{{' }} $value {{ '}}' }} I/O errors
            on {{ '{{' }} $labels.instance {{ '}}' }}

      - alert: ZFSScrubOverdue
        expr: monitoring_zfs_scrub_age_days > 8
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            ZFS pool {{ '{{' }} $labels.pool {{ '}}' }} scrub is
            {{ '{{' }} $value {{ '}}' }} days overdue
            on {{ '{{' }} $labels.instance {{ '}}' }}

  - name: kubernetes
    rules:
      - alert: KubeAPIServerDown
        expr: up{job="kube-apiserver"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "Kubernetes API server is unreachable"

      - alert: EtcdDown
        expr: up{job="etcd"} == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: "etcd is unreachable on {{ '{{' }} $labels.instance {{ '}}' }}"

      - alert: EtcdDbSizeLarge
        expr: etcd_mvcc_db_total_size_in_bytes > 4294967296
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            etcd database is {{ '{{' }} $value | humanize1024 {{ '}}' }}B
            (threshold 4GB)

  - name: observability
    rules:
      - alert: TargetDown
        expr: up == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            Scrape target {{ '{{' }} $labels.job {{ '}}' }}/{{ '{{' }} $labels.instance {{ '}}' }}
            is down

      - alert: PrometheusWatchdog
        expr: vector(1)
        labels:
          severity: none
        annotations:
          summary: "Prometheus watchdog — this alert should always be firing"

  - name: foundation-stores
    rules:
      - alert: PostgresConnectionsHigh
        expr: pg_stat_activity_count > 80
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            PostgreSQL has {{ '{{' }} $value {{ '}}' }} active connections
            (max 100)

      - alert: PostgresDown
        expr: pg_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "PostgreSQL exporter cannot connect to database"

      - alert: RedisMemoryHigh
        expr: redis_memory_used_bytes / redis_memory_max_bytes > 0.85
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Redis memory at {{ '{{' }} $value | humanizePercentage {{ '}}' }}
            of limit

      - alert: RedisDown
        expr: redis_up == 0
        for: 1m
        labels:
          severity: critical
        annotations:
          summary: "Redis exporter cannot connect to Redis"

      - alert: RedisEvictions
        expr: rate(redis_evicted_keys_total[5m]) > 0
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: "Redis is evicting keys — memory pressure"

  - name: endpoints
    rules:
      - alert: EndpointDown
        expr: probe_success == 0
        for: 2m
        labels:
          severity: critical
        annotations:
          summary: >-
            {{ '{{' }} $labels.instance {{ '}}' }} is unreachable

      - alert: SSLCertExpiringSoon
        expr: probe_ssl_earliest_cert_expiry - time() < 86400 * 14
        for: 1h
        labels:
          severity: warning
        annotations:
          summary: >-
            SSL certificate for {{ '{{' }} $labels.instance {{ '}}' }}
            expires in less than 14 days

  - name: containers
    rules:
      - alert: ContainerCPUHigh
        expr: rate(container_cpu_usage_seconds_total{name!=""}[5m]) > 0.9
        for: 10m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} CPU usage above 90%

      - alert: ContainerMemoryHigh
        expr: container_memory_usage_bytes{name!=""} / container_spec_memory_limit_bytes{name!=""} > 0.9
        for: 5m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} memory at
            {{ '{{' }} $value | humanizePercentage {{ '}}' }} of limit

      - alert: ContainerRestarting
        expr: increase(container_restart_count{name!=""}[15m]) > 3
        for: 0m
        labels:
          severity: warning
        annotations:
          summary: >-
            Container {{ '{{' }} $labels.name {{ '}}' }} restarted
            {{ '{{' }} $value {{ '}}' }} times in 15 minutes
