# Managed by Ansible — r730xd-prometheus role
# Hubble metrics targets for K8s cluster nodes (Phase 2.5)
{% for host in groups['k8s_cluster'] %}
- targets:
    - "{{ hostvars[host]['ansible_host'] }}:9965"
  labels:
    env: "grizzly-platform"
    instance: "{{ host }}"
    component: "hubble"
{% endfor %}
