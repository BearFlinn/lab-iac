# Managed by Ansible — r730xd-prometheus role
# Cilium operator metrics target (Phase 2.5)
# Operator runs as a single-replica Deployment with hostNetwork on the control plane.
{% for host in groups['k8s_control_plane'] %}
- targets:
    - "{{ hostvars[host]['ansible_host'] }}:9963"
  labels:
    env: "grizzly-platform"
    instance: "{{ host }}"
    component: "cilium-operator"
{% endfor %}
