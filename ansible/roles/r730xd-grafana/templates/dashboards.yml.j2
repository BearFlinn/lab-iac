# Managed by Ansible — r730xd-grafana role
# Grafana dashboard provisioning

apiVersion: 1

providers:
  - name: Homelab
    orgId: 1
    folder: Homelab
    type: file
    disableDeletion: false
    editable: true
    updateIntervalSeconds: 30
    options:
      path: /var/lib/grafana/dashboards
      foldersFromFilesStructure: false
