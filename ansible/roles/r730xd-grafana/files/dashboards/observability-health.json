{
  "annotations": { "list": [] },
  "description": "Health metrics for the observability stack: Prometheus, Alertmanager, Loki, Tempo, Grafana",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Prometheus",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Targets Up",
      "type": "stat",
      "targets": [{ "expr": "count(up == 1)", "legendFormat": "up" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Targets Down",
      "type": "stat",
      "targets": [{ "expr": "count(up == 0) or vector(0)", "legendFormat": "down" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 10 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Active Alerts",
      "type": "stat",
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "firing" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "TSDB Size",
      "type": "stat",
      "targets": [{ "expr": "prometheus_tsdb_storage_blocks_bytes", "legendFormat": "blocks" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "WAL Size",
      "type": "stat",
      "targets": [{ "expr": "prometheus_tsdb_wal_storage_size_bytes", "legendFormat": "WAL" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Time Series Count",
      "type": "stat",
      "targets": [{ "expr": "prometheus_tsdb_head_series", "legendFormat": "series" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 7,
      "title": "Scrape Duration",
      "type": "timeseries",
      "targets": [{ "expr": "scrape_duration_seconds", "legendFormat": "{{ job }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "id": 8,
      "title": "Rule Evaluation Duration",
      "type": "timeseries",
      "targets": [{ "expr": "prometheus_rule_group_duration_seconds{quantile=\"0.99\"}", "legendFormat": "{{ rule_group }} p99" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 200,
      "title": "Alertmanager",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "fillOpacity": 50 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 9,
      "title": "Notifications Sent",
      "type": "timeseries",
      "targets": [
        { "expr": "rate(alertmanager_notifications_total[5m])", "legendFormat": "{{ integration }} (total)" },
        { "expr": "rate(alertmanager_notifications_failed_total[5m])", "legendFormat": "{{ integration }} (failed)" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "title": "Alert Groups",
      "type": "timeseries",
      "targets": [{ "expr": "alertmanager_alerts", "legendFormat": "{{ state }}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "Loki",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 11,
      "title": "Log Ingestion Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(loki_distributor_bytes_received_total[5m])", "legendFormat": "bytes/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 12,
      "title": "Log Lines Ingested",
      "type": "timeseries",
      "targets": [{ "expr": "rate(loki_distributor_lines_received_total[5m])", "legendFormat": "lines/s" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "Tempo",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 13,
      "title": "Trace Ingestion Rate",
      "type": "timeseries",
      "targets": [{ "expr": "rate(tempo_distributor_bytes_received_total[5m])", "legendFormat": "bytes/s" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "id": 14,
      "title": "Spans Ingested",
      "type": "timeseries",
      "targets": [{ "expr": "rate(tempo_distributor_spans_received_total[5m])", "legendFormat": "spans/s" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 500,
      "title": "Grafana",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 41 },
      "id": 15,
      "title": "HTTP Request Duration (p99)",
      "type": "timeseries",
      "targets": [{ "expr": "histogram_quantile(0.99, rate(grafana_http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 41 },
      "id": 16,
      "title": "Active Grafana Sessions",
      "type": "timeseries",
      "targets": [{ "expr": "grafana_stat_active_users", "legendFormat": "users" }]
    }
  ],
  "schemaVersion": 39,
  "tags": ["grizzly-platform", "observability", "prometheus", "loki", "tempo", "grafana"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Observability Health",
  "uid": "observability-health",
  "version": 1
}
