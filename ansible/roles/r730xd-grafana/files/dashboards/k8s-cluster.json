{
  "annotations": { "list": [] },
  "description": "Kubernetes cluster health: node status, pod counts, kubelet, Cilium, Hubble, and storage metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Cluster Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Nodes Total",
      "type": "stat",
      "targets": [{ "expr": "count(kube_node_info)", "legendFormat": "nodes" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 4 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Nodes Ready",
      "type": "stat",
      "targets": [{ "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\"} == 1)", "legendFormat": "ready" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Pods Running",
      "type": "stat",
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=\"Running\"} == 1)", "legendFormat": "running" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "blue", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "title": "Pods Total",
      "type": "stat",
      "targets": [{ "expr": "count(kube_pod_info)", "legendFormat": "total" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 3 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Pods Not Running",
      "type": "stat",
      "targets": [{ "expr": "count(kube_pod_status_phase{phase=~\"Pending|Failed|Unknown\"} == 1) or vector(0)", "legendFormat": "not running" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 0 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "K8s Alerts Firing",
      "type": "stat",
      "targets": [{ "expr": "count(ALERTS{alertstate=\"firing\",alertname=~\"Node.*|Kubelet.*|Cilium.*|Kube.*|Etcd.*|ISCSI.*|Democratic.*|PVC.*\"}) or vector(0)", "legendFormat": "firing" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "Node Resources",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 7,
      "title": "CPU Allocatable per Node",
      "type": "timeseries",
      "targets": [{ "expr": "kube_node_status_allocatable{resource=\"cpu\"}", "legendFormat": "{{ node }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 8,
      "title": "Memory Allocatable per Node",
      "type": "timeseries",
      "targets": [{ "expr": "kube_node_status_allocatable{resource=\"memory\"}", "legendFormat": "{{ node }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 9,
      "title": "CPU Requests per Node",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (node) (kube_pod_container_resource_requests{resource=\"cpu\"})", "legendFormat": "{{ node }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "title": "Memory Requests per Node",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (node) (kube_pod_container_resource_requests{resource=\"memory\"})", "legendFormat": "{{ node }}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 300,
      "title": "Kubelet",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 4 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 23 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Kubelets Up",
      "type": "stat",
      "targets": [{ "expr": "count(up{job=\"kubelet\"} == 1)", "legendFormat": "up" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 23 },
      "id": 12,
      "title": "Running Pods per Node (kubelet)",
      "type": "timeseries",
      "targets": [{ "expr": "kubelet_running_pods", "legendFormat": "{{ instance }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 23 },
      "id": 13,
      "title": "Running Containers per Node (kubelet)",
      "type": "timeseries",
      "targets": [{ "expr": "kubelet_running_containers{container_state=\"running\"}", "legendFormat": "{{ instance }}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "Cilium",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 4 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 32 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Cilium Agents Up",
      "type": "stat",
      "targets": [{ "expr": "count(up{job=\"cilium-agent\"} == 1)", "legendFormat": "up" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 32 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Cilium Operator Up",
      "type": "stat",
      "targets": [{ "expr": "count(up{job=\"cilium-operator\"} == 1)", "legendFormat": "up" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 32 },
      "id": 16,
      "title": "Cilium Endpoints per Node",
      "type": "timeseries",
      "targets": [{ "expr": "cilium_endpoint", "legendFormat": "{{ instance }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 32 },
      "id": 17,
      "title": "Cilium Forwarded Packets",
      "type": "timeseries",
      "targets": [
        { "expr": "sum by (direction) (rate(cilium_forward_count_total[5m]))", "legendFormat": "{{ direction }}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 },
      "id": 500,
      "title": "Hubble",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 4 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 41 },
      "id": 18,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "Hubble Targets Up",
      "type": "stat",
      "targets": [{ "expr": "count(up{job=\"hubble\"} == 1)", "legendFormat": "up" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 41 },
      "id": 19,
      "title": "Hubble Flows Processed",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (instance) (rate(hubble_flows_processed_total[5m]))", "legendFormat": "{{ instance }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 41 },
      "id": 20,
      "title": "Hubble DNS Responses",
      "type": "timeseries",
      "targets": [{ "expr": "sum by (rcode) (rate(hubble_dns_responses_total[5m]))", "legendFormat": "{{ rcode }}" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 49 },
      "id": 600,
      "title": "Storage",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 50 },
      "id": 21,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "PVCs by StorageClass",
      "type": "stat",
      "targets": [{ "expr": "count by (storageclass) (kube_persistentvolumeclaim_info)", "legendFormat": "{{ storageclass }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 }
          ]}
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Bound" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Pending" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Lost" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 50 },
      "id": 22,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "PVCs by Phase",
      "type": "stat",
      "targets": [{ "expr": "count by (phase) (kube_persistentvolumeclaim_status_phase == 1)", "legendFormat": "{{ phase }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "green", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 50 },
      "id": 23,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "CSI Driver Pods Ready",
      "type": "stat",
      "targets": [{ "expr": "count(kube_pod_status_ready{namespace=\"democratic-csi\", condition=\"true\"} == 1) or vector(0)", "legendFormat": "ready" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "color": "green", "value": null }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 50 },
      "id": 24,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "title": "iSCSI Zvol Count",
      "type": "stat",
      "targets": [{ "expr": "monitoring_zfs_zvol_count{parent=\"tank/iscsi\"}", "legendFormat": "zvols" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.8 },
            { "color": "red", "value": 0.95 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 54 },
      "id": 25,
      "title": "PV Usage %",
      "type": "timeseries",
      "targets": [{ "expr": "kubelet_volume_stats_used_bytes / kubelet_volume_stats_capacity_bytes", "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }}" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 54 },
      "id": 26,
      "title": "PV Capacity (Used vs Available)",
      "type": "timeseries",
      "targets": [
        { "expr": "kubelet_volume_stats_used_bytes", "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }} used" },
        { "expr": "kubelet_volume_stats_available_bytes", "legendFormat": "{{ namespace }}/{{ persistentvolumeclaim }} avail" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["grizzly-platform", "kubernetes", "cilium", "hubble", "storage"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "K8s Cluster",
  "uid": "k8s-cluster",
  "version": 1
}
