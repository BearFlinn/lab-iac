#!/usr/bin/env bash
# Managed by Ansible — r730xd-openbao role
# Block until OpenBao's API is reachable. Succeeds whether the vault is
# sealed or unsealed — we just need the HTTP listener to be accepting
# connections before openbao-auto-unseal.sh can talk to it.
#
# Exit 0: API responded (any 2xx/4xx/5xx status counts — socket is open
#         and TLS handshake completed).
# Exit 1: no response within timeout.

set -euo pipefail

ADDR="{{ openbao_loopback_addr }}"
CA_CERT="{{ openbao_tls_dir }}/ca.crt"
DEADLINE=$((SECONDS + 120))

log() { echo "[openbao-wait-ready] $*"; }

log "waiting for ${ADDR}/v1/sys/health (up to 120s)"

while [ "${SECONDS}" -lt "${DEADLINE}" ]; do
    # --cacert means we verify the self-signed CA. We intentionally do
    # NOT use -k — if the cert is broken, auto-unseal should fail loudly
    # rather than silently talking to an impostor.
    if curl --silent --show-error --fail-with-body \
        --cacert "${CA_CERT}" \
        --connect-timeout 3 --max-time 5 \
        -o /dev/null -w "%{http_code}" \
        "${ADDR}/v1/sys/health?sealedcode=200&uninitcode=200" \
        >/dev/null 2>&1; then
        log "OpenBao API is reachable"
        exit 0
    fi
    sleep 2
done

log "ERROR: OpenBao API did not respond within 120s"
exit 1
