#!/usr/bin/env bash
# Managed by Ansible — r730xd-openbao role
# Daily Raft snapshot with rotation. Mirrors the r730xd-postgres backup
# pattern. Snapshots are encrypted by OpenBao's seal wrap — they are safe
# to store on the same volume as the live data, but ZFS snapshots of
# {{ openbao_data_dir }} provide a second, independent recovery path.

set -euo pipefail

BACKUP_DIR="{{ openbao_backup_dir }}"
RETENTION_DAYS="{{ openbao_backup_retention_days }}"
CA_CERT="{{ openbao_tls_dir }}/ca.crt"
ADDR="{{ openbao_loopback_addr }}"
AUTH_FILE="{{ openbao_infisical_auth_env_file }}"
TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
SNAPSHOT_FILE="${BACKUP_DIR}/openbao-raft-${TIMESTAMP}.snap"

export VAULT_ADDR="${ADDR}"
export BAO_ADDR="${ADDR}"
export VAULT_CACERT="${CA_CERT}"
export BAO_CACERT="${CA_CERT}"

# Snapshot save requires a token. Use the root token from Infisical —
# this is acceptable for a batch job because the token never leaves the
# box. A future tightening would be to mint a dedicated snapshot-only
# token during bootstrap and store *that* in Infisical instead.
# shellcheck disable=SC1090
source "${AUTH_FILE}"

INFISICAL_TOKEN="$(infisical login \
    --method=universal-auth \
    --client-id="${INFISICAL_CLIENT_ID}" \
    --client-secret="${INFISICAL_CLIENT_SECRET}" \
    --plain --silent)"

BAO_TOKEN="$(infisical secrets get OPENBAO_ROOT_TOKEN \
    --projectId="${INFISICAL_PROJECT_ID}" \
    --env="${INFISICAL_ENV}" \
    --token="${INFISICAL_TOKEN}" \
    --plain --silent)"

export VAULT_TOKEN="${BAO_TOKEN}"
export BAO_TOKEN

bao operator raft snapshot save "${SNAPSHOT_FILE}"
unset VAULT_TOKEN BAO_TOKEN

if [ ! -s "${SNAPSHOT_FILE}" ]; then
    echo "ERROR: snapshot file is empty: ${SNAPSHOT_FILE}" >&2
    rm -f "${SNAPSHOT_FILE}"
    exit 1
fi

find "${BACKUP_DIR}" -name "openbao-raft-*.snap" -mtime "+${RETENTION_DAYS}" -delete

echo "Snapshot complete: ${SNAPSHOT_FILE} ($(du -h "${SNAPSHOT_FILE}" | cut -f1))"
