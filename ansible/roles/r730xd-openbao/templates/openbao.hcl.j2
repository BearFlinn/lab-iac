# Managed by Ansible — r730xd-openbao role
# OpenBao server configuration. LAN-only HTTPS, integrated Raft storage.

ui = true
cluster_name = "lab-iac"
# OpenBao 2.5+ dropped mlock support entirely; setting disable_mlock
# now errors. Swap must be disabled or encrypted on the host instead —
# see https://openbao.org/docs/install/#post-installation-hardening

storage "raft" {
  path    = "/openbao/data"
  node_id = "{{ openbao_node_id }}"
}

listener "tcp" {
  address         = "0.0.0.0:{{ openbao_api_port }}"
  cluster_address = "0.0.0.0:{{ openbao_cluster_port }}"
  tls_cert_file   = "/openbao/config/tls/server.crt"
  tls_key_file    = "/openbao/config/tls/server.key"
  tls_min_version = "tls12"
}

api_addr     = "{{ openbao_api_addr }}"
cluster_addr = "{{ openbao_cluster_addr }}"

# Prometheus metrics are exposed at /v1/sys/metrics?format=prometheus
# and require a valid token (see prometheus-readonly policy, set up in
# bootstrap-openbao.yml).
telemetry {
  prometheus_retention_time = "30s"
  disable_hostname          = true
}

# Audit device — declared in-config so it's always enabled on boot.
# The API-based `bao audit enable` path returned 400 on the 2.5.0-beta
# during initial bootstrap (issue openbao/openbao#2168); the fix landed
# in PR #2170 on release/2.5.x and is in v2.5.2, so declarative config
# works. Shape comes from openbao.org/docs/configuration/audit/:
#   audit "<type>" "<path>" { options { ... } }
# The outer quoted tokens are type + path-within-the-audit-backend; no
# two audit blocks may share the same path. Audit semantics are "all
# devices receive the write; if all fail, the request fails." We run
# one file device; the brick-on-ENOSPC risk is mitigated by logrotate
# copytruncate (see defaults/main.yml) and the OpenbaoAuditLogDiskFull
# Prometheus alert.
audit "file" "main" {
  description = "Primary audit log — JSON lines on the ZFS hot tier"
  options {
    # In-container path. The host path ({{ openbao_audit_dir }}) is bind-
    # mounted to /openbao/audit in docker-compose.yml.j2.
    file_path     = "/openbao/audit/audit.log"
    format        = "json"
    log_raw       = "false"
    hmac_accessor = "true"
    mode          = "0600"
  }
}

# Log level: INFO in steady state; flip to DEBUG transiently via
# `bao monitor -log-level=debug` when troubleshooting.
log_level = "info"
