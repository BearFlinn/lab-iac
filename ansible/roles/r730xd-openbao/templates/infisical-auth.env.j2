# Managed by Ansible — r730xd-openbao role
# Universal-auth credentials for the bootstrap Infisical machine identity.
# Permissions: 0600, owner root. Read by openbao-auto-unseal.sh on every boot.
#
# Rotate via: ansible-playbook ansible/playbooks/rotate-openbao-keys.yml \
#   --tags infisical-identity
INFISICAL_CLIENT_ID={{ openbao_infisical_client_id }}
INFISICAL_CLIENT_SECRET={{ openbao_infisical_client_secret }}
INFISICAL_PROJECT_ID={{ openbao_infisical_project_id }}
INFISICAL_ENV={{ openbao_infisical_env }}
