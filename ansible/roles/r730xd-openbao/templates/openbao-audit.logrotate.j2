# Managed by Ansible — r730xd-openbao role
# OpenBao never rotates its own audit log. If the file is moved or
# deleted while OpenBao is running, audit writes will start failing and
# — because audit is required for every request — OpenBao will start
# rejecting requests. `copytruncate` avoids the inode swap, and we then
# send SIGHUP to the container so OpenBao re-opens the file handle.
{{ openbao_audit_log_file }} {
    {{ openbao_audit_logrotate_frequency }}
    rotate {{ openbao_audit_logrotate_rotate_count }}
    compress
    delaycompress
    missingok
    notifempty
    copytruncate
    create 0600 root root
    postrotate
        /usr/bin/docker kill --signal=SIGHUP foundation-openbao > /dev/null 2>&1 || true
    endscript
}
