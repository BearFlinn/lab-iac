# Garage Configuration - Managed by Ansible
# tower-pc Single-Node S3 Object Storage

metadata_dir = "{{ garage_metadata_dir }}"
data_dir = "{{ garage_data_dir }}"

db_engine = "{{ garage_db_engine }}"
replication_factor = {{ garage_replication_factor }}
block_size = "{{ garage_block_size }}"
compression_level = {{ garage_compression_level }}

rpc_bind_addr = "[::]:{{ garage_rpc_port }}"
rpc_public_addr = "{{ ansible_host }}:{{ garage_rpc_port }}"
rpc_secret_file = "/etc/garage/rpc_secret"

[s3_api]
api_bind_addr = "[::]:{{ garage_s3_port }}"
s3_region = "{{ garage_s3_region }}"

[s3_web]
bind_addr = "[::]:{{ garage_web_port }}"
root_domain = ".web.garage.local"
index = "index.html"

[admin]
api_bind_addr = "0.0.0.0:{{ garage_admin_port }}"
admin_token_file = "/etc/garage/admin_token"
metrics_token_file = "/etc/garage/metrics_token"
