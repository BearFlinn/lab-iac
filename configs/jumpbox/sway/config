# Jumpbox Sway config — minimal lab command center
# See `man 5 sway` for reference

### Variables
set $mod Mod4
set $term foot
set $menu wmenu-run

### Output
# No wallpaper — solid dark background
output * bg #1a1a2e solid_color

### Input
# Repeat rate for keyboard-heavy usage
input type:keyboard {
    repeat_delay 300
    repeat_rate 40
}

### Idle / Lock
exec swayidle -w \
    timeout 600 'swaylock -f -c 1a1a2e' \
    timeout 900 'swaymsg "output * power off"' \
    resume 'swaymsg "output * power on"'

### Autostart
exec waybar
exec mako

### Key bindings — basics
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+Shift+q kill
bindsym $mod+Shift+e exec swaymsg exit
bindsym $mod+Shift+c reload
bindsym $mod+l exec swaylock -f -c 1a1a2e

# Focus
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layout
bindsym $mod+h splith
bindsym $mod+v splitv
bindsym $mod+f fullscreen toggle
bindsym $mod+space floating toggle
bindsym $mod+Shift+space focus mode_toggle

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4

# Resize mode
mode "resize" {
    bindsym Left resize shrink width 10px
    bindsym Down resize grow height 10px
    bindsym Up resize shrink height 10px
    bindsym Right resize grow width 10px
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

# Screenshot
bindsym Print exec grim - | wl-copy
bindsym $mod+Print exec grim -g "$(slurp)" - | wl-copy

### Appearance
default_border pixel 2
gaps inner 4
font pango:monospace 10

# Colors (dark minimal)
# class                 border  bg      text    indicator child_border
client.focused          #7aa2f7 #1a1a2e #c0caf5 #7aa2f7   #7aa2f7
client.unfocused        #333333 #1a1a2e #888888 #333333   #333333
client.focused_inactive #333333 #1a1a2e #888888 #333333   #333333
